// Prisma Schema for WatashiWa (SRS App)
// FSRS-compatible vocabulary learning system

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// User Model for Multi-tenancy
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  avatarUrl String?   @map("avatar_url")

  role UserRole @default(USER)

  // Learning Limits
  limitNewCards Int @default(20) @map("limit_new_cards")
  limitReviews  Int @default(200) @map("limit_reviews")

  // Study Preferences
  allowSpaceKey       Boolean @default(true) @map("allow_space_key")
  spaceKeyRating      Int     @default(3) @map("space_key_rating") // 1=Again, 2=Hard, 3=Good, 4=Easy
  autoShowAnswer      Boolean @default(false) @map("auto_show_answer")
  autoShowAnswerDelay Int     @default(40) @map("auto_show_answer_delay") // Seconds
  timezone            String  @default("UTC")

  // Gamification
  currentStreak Int @default(0) @map("current_streak")
  longestStreak Int @default(0) @map("longest_streak")

  // Tutorial & Feature Flags
  // Flexible JSON to track seen tutorials, one-time banners, etc.
  // e.g. { "study_page": true, "christmas_2025": true }
  tutorials Json @default("{}")

  // Relations
  studyCards      StudyCard[]
  reviewLogs      ReviewLog[]
  reportsSent     CardReport[]  @relation("ReportedBy")
  reportsResolved CardReport[]  @relation("ResolvedBy")
  decks           Deck[]
  cardComments    CardComment[]
  commentVotes    CommentVote[]
  createdCourses  Course[]
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

// Deck Model: A collection of vocabulary
model Deck {
  id            String  @id @default(uuid())
  title         String
  titleEn       String? @map("title_en")
  description   String?
  descriptionEn String? @map("description_en")
  isPublic      Boolean @default(false) @map("is_public")
  headerImage   String? @map("header_image")
  sortOrder     Int?    @map("sort_order") // For explicit deck ordering on /decks page

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  vocab Vocab[]
  kanji Kanji[]

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  courseDecks CourseDeck[]

  @@index([authorId])
}

// Vocab Model: The definition/content of a word
model Vocab {
  id     String @id @default(uuid())
  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  wordSurface     String  @map("word_surface") // e.g., 学生
  readingKana     String? @map("reading_kana") // e.g., がくせい
  wordParts       Json?   @map("word_parts") // e.g., [{"text": "...", "furigana": "...", "romaji": "..."}]
  // JSON fields require careful mapping in Prisma
  kanjiBreakdown  Json    @map("kanji_breakdown") // e.g., [{"kanji": "学", "han_viet": "HỌC", "meaning": "study"}]
  hanViet         String  @map("han_viet") // e.g., HỌC SINH
  meaning         String // Native definition (VN)
  enMeaning       String? @map("en_meaning") // English definition
  exampleSentence Json    @map("example_sentence") // { "sentence": "...", "translation": "..." }
  audioUrl        String? @map("audio_url")
  imageUrl        String? @map("image_url")

  // Relations
  studyCards StudyCard[]

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  cardReports  CardReport[]
  cardComments CardComment[]

  @@index([deckId])
}

// Kanji Model: For single Kanji character learning
model Kanji {
  id     String @id @default(uuid())
  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  kanji     String
  onyomi    String[] // e.g. ["ニチ", "ジツ"]
  kunyomi   String[] // e.g. ["ひ", "び", "か"]
  strokes   Int
  hanViet   String   @map("han_viet")
  meaning   String
  jlptLevel String?  @map("jlpt_level") // N5, N4...
  imageUrl  String?  @map("image_url")
  radicals  Json // e.g. [{ "kanji": "日", "hanViet": "...", "meaning": "..." }]
  examples  Json // e.g. [{ "word": "...", "kana": "...", "meaning": "..." }]

  // Relations
  studyCards StudyCard[]

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  cardReports  CardReport[]
  cardComments CardComment[]

  @@index([deckId])
}

// StudyCard Model: A user's progress on a specific Vocab OR Kanji (FSRS data)
// Previously VocabCard
model StudyCard {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Polymorphic relation: either vocab or kanji must be set, but not both (enforced by app logic)
  vocabId String? @map("vocab_id")
  vocab   Vocab?  @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  kanjiId String? @map("kanji_id")
  kanji   Kanji?  @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  // FSRS Fields
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0) @map("elapsed_days")
  scheduledDays Int       @default(0) @map("scheduled_days")
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lastReview    DateTime? @map("last_review")

  reviewLogs ReviewLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([vocabId])
  @@index([kanjiId])
  @@index([due])
  @@index([state])
}

model ReviewLog {
  id String @id @default(uuid())

  cardId String    @map("card_id")
  card   StudyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  review DateTime @default(now())

  scheduledDays Int @map("scheduled_days")
  elapsedDays   Int @map("elapsed_days")
  state         Int

  @@index([cardId])
  @@index([review])
  @@index([userId])
}

// Card Reporting System
model CardReport {
  id String @id @default(uuid())

  // What is being reported
  vocabId String? @map("vocab_id")
  vocab   Vocab?  @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  kanjiId String? @map("kanji_id")
  kanji   Kanji?  @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  // Who reported
  reporterId String @map("reporter_id")
  reporter   User   @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  // Report details
  type           ReportType
  field          String? // Which field is incorrect (e.g., "readingKana", "meaning")
  currentValue   String?    @map("current_value")
  suggestedValue String?    @map("suggested_value")
  notes          String?

  // Resolution
  status       ReportStatus @default(PENDING)
  resolvedById String?      @map("resolved_by_id")
  resolvedBy   User?        @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolution   String? // Reason for reject, or confirmation message
  resolvedAt   DateTime?    @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([vocabId])
  @@index([kanjiId])
  @@index([reporterId])
}

enum ReportType {
  INCORRECT_READING
  INCORRECT_MEANING
  INCORRECT_HAN_VIET
  TYPO
  MISSING_AUDIO
  WRONG_EXAMPLE
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  ACCEPTED
  REJECTED
  DUPLICATE
}

// Community Comments System
model CardComment {
  id String @id @default(uuid())

  // Polymorphic: attach to Vocab OR Kanji
  vocabId String? @map("vocab_id")
  vocab   Vocab?  @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  kanjiId String? @map("kanji_id")
  kanji   Kanji?  @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content String
  type    CommentType @default(GENERAL)

  // Votes cache (optional, but good for sorting)
  upvotes   Int @default(0)
  downvotes Int @default(0)
  score     Int @default(0)

  isPinned Boolean @default(false) @map("is_pinned")
  isHidden Boolean @default(false) @map("is_hidden")

  votes CommentVote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vocabId])
  @@index([kanjiId])
  @@index([authorId])
  @@index([score]) // For trending queries
}

enum CommentType {
  MNEMONIC
  USAGE_TIP
  CULTURAL_NOTE
  EXAMPLE
  GRAMMAR
  GENERAL
}

model CommentVote {
  id String @id @default(uuid())

  commentId String      @map("comment_id")
  comment   CardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  value Int // +1 or -1

  @@unique([commentId, userId])
  @@index([commentId])
}

// Course System
model Course {
  id            String  @id @default(uuid())
  title         String
  titleEn       String? @map("title_en")
  description   String?
  descriptionEn String? @map("description_en")
  isPublic      Boolean @default(false) @map("is_public")
  headerImage   String? @map("header_image")

  // Metadata
  level String?
  tags  String[]

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations
  decks CourseDeck[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([authorId])
}

model CourseDeck {
  id String @id @default(uuid())

  courseId String @map("course_id")
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([courseId, deckId])
  @@index([courseId])
  @@index([deckId])
}
