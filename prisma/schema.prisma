// Prisma Schema for Watashi JP (JLPT SRS App)
// FSRS-compatible vocabulary learning system

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User Model for Multi-tenancy
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  decks      Deck[] // Decks created by user
  studyCards StudyCard[]
  reviewLogs ReviewLog[]
}

// Deck Model: A collection of vocabulary
model Deck {
  id          String  @id @default(uuid())
  title       String
  description String?
  isPublic    Boolean @default(false) @map("is_public")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  vocab Vocab[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([authorId])
}

// Vocab Model: The definition/content of a word
model Vocab {
  id     String @id @default(uuid())
  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  wordSurface     String @map("word_surface") // e.g., 学生
  readingKana     String @map("reading_kana") // e.g., がくせい
  // JSON fields require careful mapping in Prisma
  kanjiBreakdown  Json   @map("kanji_breakdown") // e.g., [{"kanji": "学", "han_viet": "HỌC", "meaning": "study"}]
  hanViet         String @map("han_viet") // e.g., HỌC SINH
  meaning         String // Native definition
  exampleSentence Json   @map("example_sentence") // { "sentence": "...", "translation": "..." }

  // Relations
  studyCards StudyCard[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([deckId])
}

// StudyCard Model: A user's progress on a specific Vocab (FSRS data)
// Previously VocabCard
model StudyCard {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  vocabId String @map("vocab_id")
  vocab   Vocab  @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  // FSRS Fields
  due           DateTime  @default(now())
  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0) @map("elapsed_days")
  scheduledDays Int       @default(0) @map("scheduled_days")
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0) // 0=New, 1=Learning, 2=Review, 3=Relearning
  lastReview    DateTime? @map("last_review")

  reviewLogs ReviewLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([vocabId])
  @@index([due])
  @@index([state])
}

model ReviewLog {
  id String @id @default(uuid())

  cardId String    @map("card_id")
  card   StudyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  review DateTime @default(now())

  scheduledDays Int @map("scheduled_days")
  elapsedDays   Int @map("elapsed_days")
  state         Int

  @@index([cardId])
  @@index([review])
  @@index([userId])
}
