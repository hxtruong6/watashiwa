// Prisma Schema for WatashiWa V2 (Hybrid SQL Architecture)
// Supports "Smart CUBE" Method, Dynamic Variants, and Interference Shielding

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// 1. USER & SYSTEM
// -----------------------------------------------------------------------------

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(USER)

  // === DAILY PACING CONTROLS ===
  limitNewCards     Int     @default(10) @map("limit_new_cards")
  limitReviews      Int     @default(50) @map("limit_reviews")
  dailyGoal         Int     @default(20) @map("daily_goal")
  enableSmartPacing Boolean @default(true) @map("enable_smart_pacing")

  // === LOCALIZATION ===
  timezone String @default("UTC")
  language String @default("en") // "en", "vi", "ja"

  // === STUDY PREFERENCES ===
  autoPlayAudio   Boolean @default(true) @map("auto_play_audio")
  showPitchAccent Boolean @default(true) @map("show_pitch_accent")
  showEtymology   Boolean @default(true) @map("show_etymology")
  enablePriming   Boolean @default(true) @map("enable_priming")

  // === NOTIFICATION SETTINGS ===
  enableNotifications Boolean @default(true) @map("enable_notifications")
  reminderTime        String? @map("reminder_time") // "HH:MM" format

  // === FLEXIBLE PREFERENCES (JSONB) ===
  // Contract: UserPreferences (tutorials, haptic, fsrsParams, etc.)
  preferences Json @default("{}") @map("preferences")

  // === GAMIFICATION ===
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastStudyDate DateTime? @map("last_study_date") @db.Date // For efficient streak calculation

  // === AUTH PROVIDER TRACKING ===
  // OAuth Provider Tracking
  // Format: [{"provider": "google", "providerId": "123456789", "lastUsed": "2024-01-15T10:00:00Z"}]
  authProviders       Json    @default("[]") @map("auth_providers")
  // Primary auth method (for display)
  primaryAuthProvider String? @map("primary_auth_provider") // "email" | "google"

  // === EMAIL VERIFICATION ===
  emailVerifiedAt             DateTime? @map("email_verified_at")
  emailVerificationOTP        String?   @map("email_verification_otp") // Hashed OTP
  emailVerificationOTPExpires DateTime? @map("email_verification_otp_expires")

  // Relations
  userReviews       UserReview[]
  reviewLogs        ReviewLog[]
  decks             Deck[]
  cardComments      CardComment[]
  createdCourses    Course[]
  pushSubscriptions PushSubscription[]
  storyLogs         StoryLog[]

  // Reports
  reportsSent     CardReport[]     @relation("ReportedBy")
  reportsResolved CardReport[]     @relation("ResolvedBy")
  commentVotes    CommentVote[]
  dailyStudyStats DailyStudyStat[]
  studySessions   StudySession[]

  @@index([email])
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model PushSubscription {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Standard Web Push keys
  endpoint String @unique
  p256dh   String
  auth     String

  // Metadata for debugging/cleaning
  userAgent   String? @map("user_agent")
  failedCount Int     @default(0) @map("failed_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

// -----------------------------------------------------------------------------
// 2. COURSE & DECK STRUCTURE
// -----------------------------------------------------------------------------

model Course {
  id            String       @id @default(uuid())
  slug          String       @unique
  title         String
  titleEn       String?      @map("title_en")
  description   String?
  descriptionEn String?      @map("description_en")
  isPublic      Boolean      @default(false) @map("is_public")
  headerImage   String?      @map("header_image")
  level         String?
  tags          String[]
  authorId      String       @map("author_id")
  author        User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  decks         CourseDeck[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  @@index([authorId])
  @@index([slug])
}

model Deck {
  id            String  @id @default(uuid())
  slug          String  @unique
  title         String
  titleEn       String? @map("title_en")
  description   String?
  descriptionEn String? @map("description_en")
  isPublic      Boolean @default(false) @map("is_public")
  headerImage   String? @map("header_image")
  sortOrder     Int?    @map("sort_order")
  authorId      String  @map("author_id")
  author        User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations to Content
  vocabularies Vocabulary[]
  stories      Story[]
  courseDecks  CourseDeck[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([authorId])
  @@index([slug])
}

model CourseDeck {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  deckId    String   @map("deck_id")
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([courseId, deckId])
  @@index([courseId])
  @@index([deckId])
}

// -----------------------------------------------------------------------------
// 3. CORE CONTENT (HYBRID SQL)
// -----------------------------------------------------------------------------

// 1. Define the Lifecycle
enum ContentStatus {
  DRAFT // Created manually, incomplete
  AI_GENERATED // Created by Script, needs Human eyes
  FLAGGED // User reported an error, needs review
  VERIFIED // Human approved (Safe for Beta users)
  PUBLISHED // Live in Production (Safe for everyone)
}

// The Anchor
model Vocabulary {
  id     String @id @default(uuid())
  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  // Smart Tagging (Replaces legacy Kanji table)
  // e.g., ["kanji", "n5", "noun", "verb-group-1"]
  tags String[]

  // Surface Forms
  wordSurface String  @map("word_surface") // Kanji: 箸. For Kanji-only, this is the Character.
  wordReading String  @map("word_reading") // Hiragana: はし. (Mandatory for sorting/search)
  wordRomaji  String? @map("word_romaji") // hashi (Optional, calculated)
  hanViet     String? @map("han_viet") // Hán Việt: TRỨ (Optional but Critical for Vietnamese)

  // Pitch & Homonyms
  // 0=Heiban (LHHHH), 1=Atamadaka (HLLLL), 2=Nakadaka (LHHHL), 3=Kakudaka (HHLLL), etc.
  pitchPattern   Int?    @map("pitch_pattern")
  pitchSvgPath   String? @map("pitch_svg_path") // Visual line path for UI
  homonymGroupId String? @map("homonym_group_id") // UUID grouping same-reading words (Hashi/Hashi)

  // Rich Data (JSONB)
  // Contract: EtymologyData (zod: EtymologySchema)
  // { "parts": [{ "kanji": "大", "han_viet": "ĐẠI" }], "note_vi": "..." }
  etymology Json @map("etymology")

  // Contract: Object with language keys.
  // {"vi": ["Đũa"], "en": ["Chopsticks", "Cutlery"]}
  meanings Json

  // Story/Mnemonic (The Hook)
  // Contract: Language-specific memory aids.
  // { "vi": "...", "en": "..." }
  mnemonic Json? @map("mnemonic")

  // Contract: Array of example objects.
  // [{"sentence": "...", "translation": {"vi": "...", "en": "..."}, "audio": "..."}]
  examples Json

  // Furigana Mapping (Precise kanji-reading alignment)
  // Contract: FuriganaMapping (zod: FuriganaMappingSchema)
  // {
  //   "mappings": [
  //     {
  //       "kanji": "休",
  //       "reading": "やす",
  //       "surfaceIndex": 0,
  //       "readingStart": 0,
  //       "readingEnd": 2
  //     }
  //   ]
  // }
  // This enables precise furigana rendering: only show reading above kanji, not above kana
  // For "休みます" with reading "やすみます", only "やす" appears above "休"
  furiganaMapping Json? @map("furigana_mapping")

  // Media
  audioUrl String? @map("audio_url") // Custom audio, priority over OS TTS
  imageUrl String? @map("image_url")

  // Lifecycle
  contentStatus ContentStatus @default(DRAFT) @map("content_status")
  // Tracks the LAST person who signed off on this word.
  verifiedAt    DateTime?     @map("verified_at")
  verifiedBy    String?       @map("verified_by") // Store Admin/Intern ID (e.g., from Clerk/Auth)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  wordOrder Int @default(0) @map("word_order")

  // Relations
  variants      CardVariant[]
  confusionsAs1 ConfusionPair[] @relation("ConfusionA")
  confusionsAs2 ConfusionPair[] @relation("ConfusionB")
  userReviews   UserReview[]
  cardComments  CardComment[]
  cardReports   CardReport[]
  // Generalized index for tag searching might be GIN index in raw SQL, 
  // but Prisma doesn't fully support querying 'has' on arrays efficiently without specific PG extensions.
  // For now, basic list filtering is acceptable.

  @@index([deckId])
  @@index([contentStatus])
  @@index([homonymGroupId])
}

// Dynamic Content (The Variants)
model CardVariant {
  id      String     @id @default(uuid())
  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  variantType VariantType @map("variant_type")

  // Polymorphic Content Payload (The "Smart" part)
  // Contract varies by variantType (zod: VariantPayloadSchema):
  // - BASIC: null
  // - CONTEXT_GAP_FILL: GapFillPayload
  // - AUDIO_MATCH: AudioMatchPayload
  contentPayload Json @map("content_payload")

  // Quality Gate
  contentStatus ContentStatus @default(DRAFT) @map("content_status")
  verifiedAt    DateTime?     @map("verified_at")
  verifiedBy    String?       @map("verified_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vocabId])
  @@index([contentStatus])
}

enum VariantType {
  BASIC
  CONTEXT_GAP_FILL
  AUDIO_MATCH
  INTERVENTION // Was PAIR_MATCH
}

// Interference Shield (The Block)
model ConfusionPair {
  id       String     @id @default(uuid())
  vocabId1 String     @map("vocab_id_1")
  vocab1   Vocabulary @relation("ConfusionA", fields: [vocabId1], references: [id], onDelete: Cascade)
  vocabId2 String     @map("vocab_id_2")
  vocab2   Vocabulary @relation("ConfusionB", fields: [vocabId2], references: [id], onDelete: Cascade)

  // Contract: ConfusionExplanation (zod: ConfusionExplanationSchema)
  // { "mnemonic": { "vi": "..." }, "item1_nuance": "...", "item2_nuance": "..." }
  explanation Json

  type ConfusionType @default(HOMONYM)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vocabId1])
  @@index([vocabId2])
}

enum ConfusionType {
  HOMONYM // Same reading, different meaning (e.g., Hashi/Hashi)
  LOOKALIKE // Visually or phonetically similar (e.g., Matsu/Motsu)
  SYNONYM // Similar meaning, different nuance (e.g., Wakaru/Shiru)
  ANTONYM // Opposites often confused (e.g., Kasu/Kariru)
  GRAMMAR // Grammatical usage or politeness (e.g., Aru/Iru)
}

// Active Priming (The Context)
model Story {
  id     String @id @default(uuid())
  unitId String @map("unit_id")
  unit   Deck   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  // Contract: StoryContent (zod: StoryContentSchema)
  // { "title": { "vi": "..." }, "body_text": "...", "highlights": [...] }
  content       Json
  audioUrl      String?       @map("audio_url")
  contentStatus ContentStatus @default(AI_GENERATED) @map("content_status")

  storyLogs StoryLog[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([unitId])
  @@index([contentStatus])
}

// Story Progress Tracker (Active Priming)
model StoryLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId     String   @map("story_id")
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now()) @map("completed_at")

  @@unique([userId, storyId])
  @@index([userId, completedAt])
  @@index([storyId])
}

// NOTE: Legacy separate Kanji model removed in favor of `Vocabulary` with tags=["kanji"].

// -----------------------------------------------------------------------------
// 4. USER PROGRESS (FSRS & MEMORY)
// -----------------------------------------------------------------------------

// Analytics: Daily Aggregation for Heatmaps & Reports
model DailyStudyStat {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             DateTime @db.Date // Store as YYYY-MM-DD
  cardsReviewed    Int      @default(0) @map("cards_reviewed")
  newCardsLearned  Int      @default(0) @map("new_cards_learned")
  reviewDurationMs Int      @default(0) @map("review_duration_ms")
  correctCount     Int      @default(0) @map("correct_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
}

// Session Persistence (Smart Queue Resume)
model StudySession {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The queue of card IDs to study in this session
  // e.g. ["uuid-1", "uuid-2"]
  queue Json

  // Current progress
  status       SessionStatus @default(ACTIVE)
  currentIndex Int           @default(0) @map("current_index")

  startedAt DateTime @default(now()) @map("started_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model UserReview {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Target Content
  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  // Note: Kanji is now reviewed as a Vocabulary item with tag="kanji"

  // FSRS Algorithms State
  srsStage     Int      @default(0) @map("srs_stage") // 0=New, 1=Learning, 2=Review, 3=Relearning
  nextReviewAt DateTime @default(now()) @map("next_review_at")

  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0) @map("elapsed_days")
  scheduledDays Int       @default(0) @map("scheduled_days")
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0)
  lastReview    DateTime? @map("last_review")

  // The 'E' in CUBE: Encoding
  personalAnchor String? @map("personal_anchor") // User's custom mnemonic
  isFavorite     Boolean @default(false) @map("is_favorite")

  reviewLogs ReviewLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, vocabId])
  // Composite Indexes for Dashboard Performance
  // "Get my due cards": WHERE user_id = ? AND next_review_at <= NOW()
  @@index([userId, nextReviewAt])
  // "Get my learning breakdown": WHERE user_id = ? AND srs_stage = ?
  @@index([userId, srsStage])
}

model ReviewLog {
  id String @id @default(uuid())

  reviewId   String     @map("review_id")
  reviewItem UserReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating     Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  reviewDate DateTime @default(now()) @map("review_date")
  duration   Int      @default(0) // Time taken in milliseconds -> know about user hesitation time response

  scheduledDays Int @map("scheduled_days")
  elapsedDays   Int @map("elapsed_days")
  state         Int // State BEFORE review

  @@index([reviewId])
  @@index([reviewDate])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// 5. COMMUNITY & REPORTING
// -----------------------------------------------------------------------------

model CardComment {
  id String @id @default(uuid())

  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content String
  type    CommentType @default(GENERAL)

  // Votes
  upvotes   Int     @default(0)
  downvotes Int     @default(0)
  score     Int     @default(0)
  isPinned  Boolean @default(false) @map("is_pinned")
  isHidden  Boolean @default(false) @map("is_hidden")

  votes CommentVote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vocabId])
}

enum CommentType {
  MNEMONIC
  USAGE_TIP
  CULTURAL_NOTE
  EXAMPLE
  GRAMMAR
  GENERAL
}

model CommentVote {
  id        String      @id @default(uuid())
  commentId String      @map("comment_id")
  comment   CardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int

  @@unique([commentId, userId])
}

model CardReport {
  id String @id @default(uuid())

  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  reporterId String @map("reporter_id")
  reporter   User   @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  type           ReportType
  field          String?
  currentValue   String?    @map("current_value")
  suggestedValue String?    @map("suggested_value")
  notes          String?

  status       ReportStatus @default(PENDING)
  resolvedById String?      @map("resolved_by_id")
  resolvedBy   User?        @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolution   String?
  resolvedAt   DateTime?    @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
}

enum ReportType {
  INCORRECT_READING
  INCORRECT_MEANING
  INCORRECT_HAN_VIET
  TYPO
  MISSING_AUDIO
  WRONG_EXAMPLE
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  ACCEPTED
  REJECTED
  DUPLICATE
}
