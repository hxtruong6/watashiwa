// Prisma Schema for WatashiWa V2 (Hybrid SQL Architecture)
// Supports "Smart CUBE" Method, Dynamic Variants, and Interference Shielding

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// 1. USER & SYSTEM
// -----------------------------------------------------------------------------

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  name      String?
  lastLogin DateTime? @map("last_login")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(USER)

  // === DAILY PACING CONTROLS ===
  limitNewCards     Int     @default(10) @map("limit_new_cards")
  limitReviews      Int     @default(50) @map("limit_reviews")
  dailyGoal         Int     @default(20) @map("daily_goal")
  enableSmartPacing Boolean @default(true) @map("enable_smart_pacing")

  // === LOCALIZATION ===
  timezone String @default("UTC")
  language String @default("en") // "en", "vi", "ja"

  // === STUDY PREFERENCES ===
  autoPlayAudio   Boolean @default(true) @map("auto_play_audio")
  showPitchAccent Boolean @default(true) @map("show_pitch_accent")
  showEtymology   Boolean @default(true) @map("show_etymology")
  enablePriming   Boolean @default(true) @map("enable_priming")

  // === NOTIFICATION SETTINGS ===
  enableNotifications Boolean @default(true) @map("enable_notifications")
  reminderTime        String? @map("reminder_time") // "HH:MM" format

  // === FLEXIBLE PREFERENCES (JSONB) ===
  // Contract: UserPreferences (tutorials, haptic, fsrsParams, etc.)
  preferences Json @default("{}") @map("preferences")

  // === GAMIFICATION ===
  currentStreak Int       @default(0) @map("current_streak")
  longestStreak Int       @default(0) @map("longest_streak")
  lastStudyDate DateTime? @map("last_study_date") @db.Date // For efficient streak calculation

  // === AUTH PROVIDER TRACKING ===
  // OAuth Provider Tracking
  // Format: [{"provider": "google", "providerId": "123456789", "lastUsed": "2024-01-15T10:00:00Z"}]
  authProviders       Json    @default("[]") @map("auth_providers")
  // Primary auth method (for display)
  primaryAuthProvider String? @map("primary_auth_provider") // "email" | "google"

  // === EMAIL VERIFICATION ===
  emailVerifiedAt             DateTime? @map("email_verified_at")
  emailVerificationOTP        String?   @map("email_verification_otp") // Hashed OTP
  emailVerificationOTPExpires DateTime? @map("email_verification_otp_expires")

  // Relations
  userReviews       UserReview[]
  reviewLogs        ReviewLog[]
  decks             Deck[]
  cardComments      CardComment[]
  createdCourses    Course[]
  pushSubscriptions PushSubscription[]
  storyLogs         StoryLog[]

  // Reports
  reportsSent     CardReport[]     @relation("ReportedBy")
  reportsResolved CardReport[]     @relation("ResolvedBy")
  commentVotes    CommentVote[]
  dailyStudyStats DailyStudyStat[]
  studySessions   StudySession[]
  videoLogs       VideoLog[]

  @@index([email])
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model PushSubscription {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Standard Web Push keys
  endpoint String @unique
  p256dh   String
  auth     String

  // Metadata for debugging/cleaning
  userAgent   String? @map("user_agent")
  failedCount Int     @default(0) @map("failed_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
}

// -----------------------------------------------------------------------------
// 2. COURSE & DECK STRUCTURE
// -----------------------------------------------------------------------------

model Course {
  id            String       @id @default(uuid())
  slug          String       @unique
  title         String
  titleEn       String?      @map("title_en")
  description   String?
  descriptionEn String?      @map("description_en")
  isPublic      Boolean      @default(false) @map("is_public")
  headerImage   String?      @map("header_image")
  level         String?
  tags          String[]
  authorId      String       @map("author_id")
  author        User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  decks         CourseDeck[]
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  @@index([authorId])
  @@index([slug])
}

model Deck {
  id            String  @id @default(uuid())
  slug          String  @unique
  title         String
  titleEn       String? @map("title_en")
  description   String?
  descriptionEn String? @map("description_en")
  isPublic      Boolean @default(false) @map("is_public")
  headerImage   String? @map("header_image")
  sortOrder     Int?    @map("sort_order")
  authorId      String  @map("author_id")
  author        User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations to Content
  vocabularies Vocabulary[]
  stories      Story[]
  courseDecks  CourseDeck[]
  videos       Video[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([authorId])
  @@index([slug])
}

model CourseDeck {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  deckId    String   @map("deck_id")
  deck      Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([courseId, deckId])
  @@index([courseId])
  @@index([deckId])
}

// -----------------------------------------------------------------------------
// 3. CORE CONTENT (HYBRID SQL)
// -----------------------------------------------------------------------------

// 1. Define the Lifecycle
enum ContentStatus {
  DRAFT // Created manually, incomplete
  AI_GENERATED // Created by Script, needs Human eyes
  FLAGGED // User reported an error, needs review
  VERIFIED // Human approved (Safe for Beta users)
  PUBLISHED // Live in Production (Safe for everyone)
}

// The Anchor
model Vocabulary {
  id     String @id @default(uuid())
  deckId String @map("deck_id")
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  // Smart Tagging (Replaces legacy Kanji table)
  // e.g., ["kanji", "n5", "noun", "verb-group-1"]
  tags String[]

  // Surface Forms
  wordSurface String  @map("word_surface") // Kanji: 箸. For Kanji-only, this is the Character.
  wordReading String  @map("word_reading") // Hiragana: はし. (Mandatory for sorting/search)
  wordRomaji  String? @map("word_romaji") // hashi (Optional, calculated)
  hanViet     String? @map("han_viet") // Hán Việt: TRỨ (Optional but Critical for Vietnamese)

  // Pitch & Homonyms
  // 0=Heiban (LHHHH), 1=Atamadaka (HLLLL), 2=Nakadaka (LHHHL), 3=Kakudaka (HHLLL), etc.
  pitchPattern   Int?    @map("pitch_pattern")
  pitchSvgPath   String? @map("pitch_svg_path") // Visual line path for UI
  homonymGroupId String? @map("homonym_group_id") // UUID grouping same-reading words (Hashi/Hashi)

  // Rich Data (JSONB)
  // Contract: EtymologyData (zod: EtymologySchema)
  // { "parts": [{ "kanji": "大", "han_viet": "ĐẠI" }], "note_vi": "..." }
  etymology Json @map("etymology")

  // Contract: Object with language keys.
  // {"vi": ["Đũa"], "en": ["Chopsticks", "Cutlery"]}
  meanings Json

  // Story/Mnemonic (The Hook)
  // Contract: Language-specific memory aids.
  // { "vi": "...", "en": "..." }
  mnemonic Json? @map("mnemonic")

  // Contract: Array of example objects.
  // [{"sentence": "...", "translation": {"vi": "...", "en": "..."}, "audio": "..."}]
  examples Json

  // Furigana Mapping (Precise kanji-reading alignment)
  // Contract: FuriganaMapping (zod: FuriganaMappingSchema)
  // {
  //   "mappings": [
  //     {
  //       "kanji": "休",
  //       "reading": "やす",
  //       "surfaceIndex": 0,
  //       "readingStart": 0,
  //       "readingEnd": 2
  //     }
  //   ]
  // }
  // This enables precise furigana rendering: only show reading above kanji, not above kana
  // For "休みます" with reading "やすみます", only "やす" appears above "休"
  furiganaMapping Json? @map("furigana_mapping")

  // Media
  audioUrl String? @map("audio_url") // Custom audio, priority over OS TTS
  imageUrl String? @map("image_url")

  // Lifecycle
  contentStatus ContentStatus @default(DRAFT) @map("content_status")
  // Tracks the LAST person who signed off on this word.
  verifiedAt    DateTime?     @map("verified_at")
  verifiedBy    String?       @map("verified_by") // Store Admin/Intern ID (e.g., from Clerk/Auth)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  wordOrder Int @default(0) @map("word_order")

  // Relations
  variants          CardVariant[]
  confusionsAs1     ConfusionPair[]    @relation("ConfusionA")
  confusionsAs2     ConfusionPair[]    @relation("ConfusionB")
  userReviews       UserReview[]
  cardComments      CardComment[]
  cardReports       CardReport[]
  kanjiCompositions KanjiComposition[]
  storyVocabularies StoryVocabulary[] // Words appearing in stories
  // Generalized index for tag searching might be GIN index in raw SQL, 
  // but Prisma doesn't fully support querying 'has' on arrays efficiently without specific PG extensions.
  // For now, basic list filtering is acceptable.

  @@index([deckId])
  @@index([contentStatus])
  @@index([homonymGroupId])
}

// Dynamic Content (The Variants)
model CardVariant {
  id      String     @id @default(uuid())
  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  variantType VariantType @map("variant_type")

  // Polymorphic Content Payload (The "Smart" part)
  // Contract varies by variantType (zod: VariantPayloadSchema):
  // - BASIC: null
  // - CONTEXT_GAP_FILL: GapFillPayload
  // - AUDIO_MATCH: AudioMatchPayload
  contentPayload Json @map("content_payload")

  // Quality Gate
  contentStatus ContentStatus @default(DRAFT) @map("content_status")
  verifiedAt    DateTime?     @map("verified_at")
  verifiedBy    String?       @map("verified_by")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vocabId])
  @@index([contentStatus])
}

enum VariantType {
  BASIC
  CONTEXT_GAP_FILL
  AUDIO_MATCH
  INTERVENTION // Was PAIR_MATCH
}

// Interference Shield (The Block)
model ConfusionPair {
  id       String     @id @default(uuid())
  vocabId1 String     @map("vocab_id_1")
  vocab1   Vocabulary @relation("ConfusionA", fields: [vocabId1], references: [id], onDelete: Cascade)
  vocabId2 String     @map("vocab_id_2")
  vocab2   Vocabulary @relation("ConfusionB", fields: [vocabId2], references: [id], onDelete: Cascade)

  // Contract: ConfusionExplanation (zod: ConfusionExplanationSchema)
  // { "mnemonic": { "vi": "..." }, "item1_nuance": "...", "item2_nuance": "..." }
  explanation Json

  type ConfusionType @default(HOMONYM)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vocabId1])
  @@index([vocabId2])
}

enum ConfusionType {
  HOMONYM // Same reading, different meaning (e.g., Hashi/Hashi)
  LOOKALIKE // Visually or phonetically similar (e.g., Matsu/Motsu)
  SYNONYM // Similar meaning, different nuance (e.g., Wakaru/Shiru)
  ANTONYM // Opposites often confused (e.g., Kasu/Kariru)
  GRAMMAR // Grammatical usage or politeness (e.g., Aru/Iru)
}

// Active Priming (The Context)
model Story {
  id     String @id @default(uuid())
  slug   String @unique // URL-friendly identifier (e.g., "daily-commute-part-1")
  unitId String @map("unit_id")
  unit   Deck   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  // Sequencing & Organization
  order Int @default(0) // Story arc sequencing (Part 1, Part 2, etc.)

  // Contract: StoryContent (zod: StoryContentSchema)
  // {
  //   "title": { "en": "...", "vi": "...", "ja": "..." },
  //   "body_text": { "en": "...", "vi": "...", "ja": "..." },
  //   "translation": { "en": "...", "vi": "..." },
  //   "highlights": [] // Now stored in StoryVocabulary table
  // }
  content Json

  // Metadata for Discovery & Filtering
  difficulty   String  @default("N5") // "N5" | "N4" | "N3" | "N2" | "N1"
  category     String  @default("daily_life") // "daily_life" | "travel" | "social" | "business"
  readTimeMin  Int     @default(2) @map("read_time_min") // Estimated read time in minutes
  thumbnailUrl String? @map("thumbnail_url") // Optional illustration

  // Media & Audio
  audioUrl String? @map("audio_url") // Optional full story narration

  // Quality Control
  contentStatus ContentStatus @default(AI_GENERATED) @map("content_status")
  verifiedAt    DateTime?     @map("verified_at")
  verifiedBy    String?       @map("verified_by")

  // Relations
  vocabularies StoryVocabulary[]
  storyLogs    StoryLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([unitId])
  @@index([slug])
  @@index([contentStatus])
  @@index([difficulty, category])
}

// Junction Table: Story ↔ Vocabulary (Many-to-Many)
// Stores position data for word highlighting in stories
model StoryVocabulary {
  id           String @id @default(uuid())
  storyId      String @map("story_id")
  vocabularyId String @map("vocabulary_id")

  // Position data for highlighting (JSONB)
  // {
  //   "en": [25, 120], // Word appears at positions 25 and 120 in English text
  //   "vi": [21, 115], // Different positions in Vietnamese
  //   "ja": [13, 98]   // Different positions in Japanese
  // }
  positions Json

  // Word metadata (denormalized for performance)
  wordSurface String @map("word_surface") // e.g., "いきます"
  wordReading String @map("word_reading") // e.g., "いきます"
  wordLength  Int    @map("word_length") // Character length for text slicing

  // Relations
  story      Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  vocabulary Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([storyId, vocabularyId])
  @@index([storyId])
  @@index([vocabularyId])
}

// Story Progress Tracker (Active Priming)
model StoryLog {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId String @map("story_id")
  story   Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)

  // Progress Tracking
  completedAt     DateTime? @map("completed_at")
  wordsCollected  Int       @default(0) @map("words_collected") // How many words user clicked
  totalWords      Int       @map("total_words") // Total words in story
  readTimeSeconds Int       @default(0) @map("read_time_seconds") // Time spent reading

  // Behavior Analytics (JSONB)
  // {
  //   "clicked_words": ["vocab-id-1", "vocab-id-2"],
  //   "translation_used": true,
  //   "paused_at": [30, 120], // Seconds when user paused
  //   "audio_plays": 5
  // }
  analytics Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, storyId])
  @@index([userId, completedAt])
  @@index([storyId])
  @@index([userId, storyId])
}

// NOTE: Legacy separate Kanji model removed in favor of `Vocabulary` with tags=["kanji"].

// -----------------------------------------------------------------------------
// 3.5 ORIGAMI KNOWLEDGE GRAPH
// -----------------------------------------------------------------------------

enum ReadingType {
  ONYOMI
  KUNYOMI
  IRREGULAR
}

model Kanji {
  id              String   @id @default(uuid())
  character       String   @unique @db.Char(1) // e.g., '先'
  meaningVi       String?  @map("meaning_vi") // Vietnamese meaning (e.g., "Trước")
  meaningEn       String?  @map("meaning_en") // English meaning (e.g., "Ahead, future")
  hanViet         String?  @map("han_viet") // Hán Việt: TIÊN (Critical for Vietnamese learners)
  onyomiReadings  String[] // e.g., ["SEN"]
  kunyomiReadings String[] // e.g., ["saki", "ma-zu"]
  jlptLevel       Int? // 5 to 1 (nullable for non-JLPT kanji)
  strokeCount     Int
  frequency       Int? // Usage frequency ranking
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  compositions KanjiComposition[]

  @@index([jlptLevel])
  @@index([frequency])
  @@map("kanji")
}

model KanjiComposition {
  id            String      @id @default(uuid())
  wordId        String      @map("word_id")
  kanjiId       String      @map("kanji_id")
  position      Int // 1st, 2nd, 3rd character in word
  activeReading String      @map("active_reading") // How this kanji is read in this word (e.g., "SEI")
  readingType   ReadingType @map("reading_type")
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  word  Vocabulary @relation(fields: [wordId], references: [id], onDelete: Cascade)
  kanji Kanji      @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  @@unique([wordId, kanjiId, position])
  @@index([kanjiId, readingType])
  @@map("kanji_composition")
}

// -----------------------------------------------------------------------------
// 4. USER PROGRESS (FSRS & MEMORY)
// -----------------------------------------------------------------------------

// Analytics: Daily Aggregation for Heatmaps & Reports
model DailyStudyStat {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date             DateTime @db.Date // Store as YYYY-MM-DD
  cardsReviewed    Int      @default(0) @map("cards_reviewed")
  newCardsLearned  Int      @default(0) @map("new_cards_learned")
  reviewDurationMs Int      @default(0) @map("review_duration_ms")
  correctCount     Int      @default(0) @map("correct_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, date])
  @@index([userId])
}

// Session Persistence (Smart Queue Resume)
model StudySession {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The queue of card IDs to study in this session
  // e.g. ["uuid-1", "uuid-2"]
  queue Json

  // Current progress
  status       SessionStatus @default(ACTIVE)
  currentIndex Int           @default(0) @map("current_index")

  startedAt DateTime @default(now()) @map("started_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model UserReview {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Target Content
  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)
  // Note: Kanji is now reviewed as a Vocabulary item with tag="kanji"

  // FSRS Algorithms State
  srsStage     Int      @default(0) @map("srs_stage") // 0=New, 1=Learning, 2=Review, 3=Relearning
  nextReviewAt DateTime @default(now()) @map("next_review_at")

  stability     Float     @default(0)
  difficulty    Float     @default(0)
  elapsedDays   Int       @default(0) @map("elapsed_days")
  scheduledDays Int       @default(0) @map("scheduled_days")
  reps          Int       @default(0)
  lapses        Int       @default(0)
  state         Int       @default(0)
  lastReview    DateTime? @map("last_review")

  // The 'E' in CUBE: Encoding
  personalAnchor String? @map("personal_anchor") // User's custom mnemonic
  isFavorite     Boolean @default(false) @map("is_favorite")

  reviewLogs ReviewLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, vocabId])
  // Composite Indexes for Dashboard Performance
  // "Get my due cards": WHERE user_id = ? AND next_review_at <= NOW()
  @@index([userId, nextReviewAt])
  // "Get my learning breakdown": WHERE user_id = ? AND srs_stage = ?
  @@index([userId, srsStage])
}

model ReviewLog {
  id String @id @default(uuid())

  reviewId   String     @map("review_id")
  reviewItem UserReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating     Int // 1=Again, 2=Hard, 3=Good, 4=Easy
  reviewDate DateTime @default(now()) @map("review_date")
  duration   Int      @default(0) // Time taken in milliseconds -> know about user hesitation time response

  scheduledDays Int @map("scheduled_days")
  elapsedDays   Int @map("elapsed_days")
  state         Int // State BEFORE review

  @@index([reviewId])
  @@index([reviewDate])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// 5. COMMUNITY & REPORTING
// -----------------------------------------------------------------------------

model CardComment {
  id String @id @default(uuid())

  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content String
  type    CommentType @default(GENERAL)

  // Votes
  upvotes   Int     @default(0)
  downvotes Int     @default(0)
  score     Int     @default(0)
  isPinned  Boolean @default(false) @map("is_pinned")
  isHidden  Boolean @default(false) @map("is_hidden")

  votes CommentVote[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([vocabId])
}

enum CommentType {
  MNEMONIC
  USAGE_TIP
  CULTURAL_NOTE
  EXAMPLE
  GRAMMAR
  GENERAL
}

model CommentVote {
  id        String      @id @default(uuid())
  commentId String      @map("comment_id")
  comment   CardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String      @map("user_id")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int

  @@unique([commentId, userId])
}

model CardReport {
  id String @id @default(uuid())

  vocabId String     @map("vocab_id")
  vocab   Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  reporterId String @map("reporter_id")
  reporter   User   @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)

  type           ReportType
  field          String?
  currentValue   String?    @map("current_value")
  suggestedValue String?    @map("suggested_value")
  notes          String?

  status       ReportStatus @default(PENDING)
  resolvedById String?      @map("resolved_by_id")
  resolvedBy   User?        @relation("ResolvedBy", fields: [resolvedById], references: [id])
  resolution   String?
  resolvedAt   DateTime?    @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
}

enum ReportType {
  INCORRECT_READING
  INCORRECT_MEANING
  INCORRECT_HAN_VIET
  TYPO
  MISSING_AUDIO
  WRONG_EXAMPLE
  DUPLICATE
  OTHER
}

enum ReportStatus {
  PENDING
  ACCEPTED
  REJECTED
  DUPLICATE
}

// -----------------------------------------------------------------------------
// 6. VIDEO LEARNING
// -----------------------------------------------------------------------------

model Video {
  id           String  @id @default(uuid())
  title        String
  titleEn      String? @map("title_en")
  description  String?
  videoUrl     String  @map("video_url") // CDN URL or external URL
  thumbnailUrl String? @map("thumbnail_url")
  duration     Int // Duration in seconds
  deckId       String? @map("deck_id") // Optional: link to deck
  deck         Deck?   @relation(fields: [deckId], references: [id], onDelete: SetNull)

  // Metadata
  level          String? // e.g., "N5", "N4", "Beginner"
  tags           String[]
  language       String   @default("ja") // Source language
  targetLanguage String   @default("vi") // Translation language

  // Content Status
  contentStatus ContentStatus @default(DRAFT) @map("content_status")
  verifiedAt    DateTime?
  verifiedBy    String?

  // Relations
  subtitles Subtitle[]
  videoLogs VideoLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deckId])
  @@index([contentStatus])
}

model Subtitle {
  id      String @id @default(uuid())
  videoId String @map("video_id")
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // Timing
  startTime Float @map("start_time") // Start time in seconds
  endTime   Float @map("end_time") // End time in seconds

  // Content
  sentence    String // Japanese sentence
  translation Json // { "vi": "...", "en": "..." }
  words       Json // Word-level timing data (see SubtitleWord type)

  // Display
  order Int // Sentence order in video

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([videoId, order])
  @@index([videoId, startTime])
}

model VideoLog {
  id      String @id @default(uuid())
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId String @map("video_id")
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // Progress
  currentTime Float   @default(0) @map("current_time") // Last watched position
  completed   Boolean @default(false)
  watchTime   Int     @default(0) @map("watch_time") // Total seconds watched

  // Analytics
  playCount   Int      @default(0) @map("play_count")
  lastWatched DateTime @default(now()) @map("last_watched")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}
