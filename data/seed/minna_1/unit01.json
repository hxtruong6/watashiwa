    "etymology": {
      "parts": [
        {
          "kanji": "私",
          "han_viet": "TƯ",
          "meaning": {
            "vi": "riêng tư, cá nhân",
            "en": "private, personal, self"
          }
        }
      ],
      "note": {
        "vi": "Chữ TƯ (私) mang nghĩa 'riêng tư'. Trong xã hội Á Đông, cái 'tôi' cá nhân thường được coi là sự riêng tư, đối lập với cái 'công' (chung).",
        "en": "The Kanji 私 combines 'grain' (禾) and 'private/self' (厶). Originally meant 'private' (opposite of public), strictly used for 'I/myself'."
      }
    },
    "meanings": {
      "vi": [
        "tôi",
        "tớ",
        "mình"
      ],
      "en": [
        "I",
        "me",
        "myself"
      ]
    },
    "examples": [
      {
        "sentence": "私は学生です。",
        "translation": {
          "vi": "Tôi là học sinh.",
          "en": "I am a student."
        }
      }
    ],
    "mnemonic": {
      "vi": "**TƯ** trang của **TÔI**.",
      "en": "**WA-TA-SHI** sounds like 'What a she!' -> 'What a she (I) am!'"
    },
    "confusions": []
  },
