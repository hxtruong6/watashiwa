{
	"name": "watashiwa",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"build:debug": "next build --debug-prerender",
		"start": "next start",
		"lint": "eslint .",
		"format": "prettier --write .",
		"check-format": "prettier --check .",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate deploy",
		"db:push": "prisma db push",
		"db:studio": "prisma studio",
		"db:seed": "prisma db seed",
		"pm2:deploy:prod": "pm2 deploy ecosystem.config.cjs vps_prod",
		"test": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest run",
		"test:watch": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest",
		"test:run": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest run",
		"test:ui": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest --ui",
		"test:db:setup": "docker compose -f docker-compose.test.yml up -d && sleep 5 && DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test npx prisma db push --accept-data-loss",
		"test:db:teardown": "docker compose -f docker-compose.test.yml down -v",
		"test:integration": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest",
		"e2e": "playwright test --reporter=list",
		"e2e:ui": "playwright test --ui",
		"e2e:headed": "playwright test --headed",
		"e2e:debug": "playwright test --debug",
		"e2e:stop": "pkill -f 'playwright|next dev' || true",
		"gen:content": "tsx scripts/generate_content.ts",
		"validate:email-templates": "tsx scripts/validate-email-templates.ts",
		"type-check": "tsc --noEmit",
		"prepare": "husky"
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.0",
		"@ant-design/nextjs-registry": "^1.3.0",
		"@google-cloud/storage": "^7.18.0",
		"@google/genai": "^1.34.0",
		"@lottiefiles/dotlottie-react": "^0.17.12",
		"@prisma/adapter-pg": "^7.2.0",
		"@prisma/client": "^7.2.0",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.4.2",
		"@sentry/nextjs": "^10.32.1",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.89.0",
		"@types/three": "^0.182.0",
		"@types/uuid": "^11.0.0",
		"@vitest/ui": "^4.0.16",
		"antd": "^6.1.2",
		"canvas-confetti": "^1.9.4",
		"date-fns": "^4.1.0",
		"dotenv": "^17.2.3",
		"framer-motion": "^12.23.26",
		"immer": "^11.1.0",
		"import-in-the-middle": "^2.0.1",
		"inngest": "^3.48.1",
		"ioredis": "^5.8.2",
		"lucide-react": "^0.562.0",
		"mailtrap": "^4.4.0",
		"mime-types": "^3.0.2",
		"mjml": "^4.18.0",
		"motion": "^12.23.26",
		"next": "16.1.1",
		"next-intl": "^4.6.1",
		"next-themes": "^0.4.6",
		"nuqs": "^2.8.6",
		"pg": "^8.16.3",
		"posthog-js": "^1.310.1",
		"posthog-node": "^5.18.0",
		"prisma": "^7.2.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-force-graph-2d": "^1.29.0",
		"require-in-the-middle": "^8.0.1",
		"three": "^0.182.0",
		"ts-fsrs": "^5.2.3",
		"tsx": "^4.21.0",
		"typescript": "^5",
		"uuid": "^13.0.0",
		"web-push": "^3.6.7",
		"yaml": "^2.8.2",
		"zod": "^4.2.1",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@playwright/test": "^1.57.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@trivago/prettier-plugin-sort-imports": "^6.0.0",
		"@types/canvas-confetti": "^1.9.0",
		"@types/mime-types": "^3.0.1",
		"@types/mjml": "^4.7.4",
		"@types/node": "^25",
		"@types/pg": "^8.16.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/web-push": "^3.6.4",
		"@vitejs/plugin-react": "^5.1.2",
		"autoprefixer": "^10.4.23",
		"eslint": "^9",
		"eslint-config-next": "16.1.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.6",
		"prettier": "^3.7.4",
		"vitest": "^4.0.16"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@prisma/engines",
			"@sentry/cli",
			"@swc/core",
			"core-js",
			"esbuild",
			"prisma",
			"sharp",
			"unrs-resolver"
		]
	},
	"type": "module"
}
