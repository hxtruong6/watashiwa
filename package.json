{
  "name": "watashiwa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "pm2:deploy:prod": "pm2 deploy ecosystem.config.cjs vps_prod",
    "test": "vitest",
    "test:run": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest run",
    "test:ui": "vitest --ui",
    "test:db:setup": "docker compose -f docker-compose.test.yml up -d && sleep 5 && DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test npx prisma db push --accept-data-loss",
    "test:db:teardown": "docker compose -f docker-compose.test.yml down -v",
    "test:integration": "DATABASE_URL=postgresql://postgres:password@localhost:5433/watashiwa_test vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "gen:content": "tsx scripts/generate_content.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@google-cloud/storage": "^7.18.0",
    "@google/genai": "^1.34.0",
    "@lottiefiles/dotlottie-react": "^0.17.10",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@sentry/nextjs": "^10.30.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.87.1",
    "@types/uuid": "^11.0.0",
    "@vitest/ui": "^4.0.16",
    "antd": "^6.1.0",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.26",
    "immer": "^11.1.0",
    "import-in-the-middle": "^2.0.0",
    "mime-types": "^3.0.2",
    "motion": "^12.23.26",
    "next": "16.0.10",
    "next-intl": "^4.5.8",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.6",
    "pg": "^8.16.3",
    "posthog-js": "^1.306.1",
    "prisma": "^7.1.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "require-in-the-middle": "^8.0.1",
    "ts-fsrs": "^5.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "yaml": "^2.8.2",
    "zod": "^4.2.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@sentry/cli",
      "@swc/core",
      "core-js",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "type": "module"
}