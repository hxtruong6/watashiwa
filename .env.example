DATABASE_URL="postgresql://postgres:xxx@db.xx.co:5432/postgres"

#== App ==
NEXT_PUBLIC_APP_URL=https://watashiwa.app
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog Analytics
# Get these from your PostHog Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_exampleKey123456
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking
# Get DSN from Sentry Project Settings -> Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional: Sentry Auth Token for uploading source maps during build
# Get this from User Settings -> Auth Tokens
# SENTRY_AUTH_TOKEN=sntry_token_...

# Observability Control
# Set to 'true' to enable Sentry/PostHog in development (localhost)
# Defaults to true in production, false in development
NEXT_PUBLIC_ENABLE_ANALYTICS=false


#== GCP Storage == for Server side. Do not add NEXT_PUBLIC_ which will expose it to client side
GCP_STORAGE_BUCKET_NAME='watashiwa_app'
GCP_STORAGE_BUCKET_PROJECT_ID='iprotect-app'
GCP_STORAGE_BUCKET_KEY_FILENAME='gcs.json'

#== Push Notifications ==
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:admin@xxx.app
CRON_SECRET=xxx