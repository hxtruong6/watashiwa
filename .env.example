DATABASE_URL="postgresql://postgres:xxx@db.xx.co:5432/postgres"

#== App ==
NEXT_PUBLIC_APP_URL=https://watashiwa.app
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog Analytics
# Get these from your PostHog Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_exampleKey123456
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry Error Tracking
# Get DSN from Sentry Project Settings -> Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional: Sentry Auth Token for uploading source maps during build
# Get this from User Settings -> Auth Tokens
# SENTRY_AUTH_TOKEN=sntry_token_...

# Observability Control
# Set to 'true' to enable Sentry/PostHog in development (localhost)
# Defaults to true in production, false in development
NEXT_PUBLIC_ENABLE_ANALYTICS=false


#== GCP Storage == for Server side. Do not add NEXT_PUBLIC_ which will expose it to client side
GCP_STORAGE_BUCKET_NAME='watashiwa_app'
GCP_STORAGE_BUCKET_PROJECT_ID='iprotect-app'
GCP_STORAGE_BUCKET_KEY_FILENAME='gcs.json'

#== Push Notifications ==
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxx
VAPID_PRIVATE_KEY=xxx
VAPID_SUBJECT=mailto:admin@xxx.app
CRON_SECRET=xxx

GEMINI_API_KEY=xxx

# for login OAuth by google
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=xxx
GOOGLE_SEARCH_CONSOLE_VERIFICATION=<verification_code>

# Inngest: Required for self-hosted Inngest server (used by start-inngest.sh)
# INNGEST_EVENT_KEY=your-event-key # only when use cloud
# INNGEST_SIGNING_KEY=your-signing-key # only when use cloud
INNGEST_EVENT_KEY=<generated-key-from-openssl>  # run: openssl rand -hex 32
INNGEST_SIGNING_KEY=<generated-key-from-openssl>  # run: openssl rand -hex 32

# Required for Next.js app to connect to Inngest server
INNGEST_DEV=http://localhost:8288  # Change to your server URL in production,
# INNGEST_DEV=http://your-server-ip:8288  # Or http://inngest.yourdomain.com:8288
INNGEST_APP_ID=watashiwa-app

# Mailtrap
MAILTRAP_API_TOKEN=your-api-token
MAILTRAP_FROM_EMAIL=noreply@watashiwa.app
MAILTRAP_FROM_NAME=WatashiWa
